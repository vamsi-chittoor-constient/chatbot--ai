# =============================================================================
# WhatsApp Bridge - Environment Variables
# =============================================================================

# Meta WhatsApp Business API credentials
# Get these from: https://developers.facebook.com/apps/ -> WhatsApp -> API Setup
WA_TOKEN="your-meta-whatsapp-api-access-token"
PHONE_NUMBER_ID="your-whatsapp-phone-number-id"
WEBHOOK_VERIFY_TOKEN="your-webhook-verification-token"

# Chatbot WebSocket URL (overridden by Docker Compose for container networking)
CHATBOT_WS_BASE_URL="ws://localhost:8000/api/v1/chat"

# Logging
LOG_LEVEL="INFO"
