# A24 Restaurant Data Pipeline - PetPooja Integration Configuration

# =============================================================================
# Database Configuration
# =============================================================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=a24_restaurant_dev
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password_here

# =============================================================================
# PetPooja API Configuration
# =============================================================================

# API Base URLs (use Sandbox for testing, Production for live)
# Sandbox URL: https://qle1yy2ydc.execute-api.ap-southeast-1.amazonaws.com/V1
# Production URL: https://api-v2.petpooja.com
PETPOOJA_BASE_URL=https://api-v2.petpooja.com

# Authentication credentials (ONLY THESE 3 ARE REQUIRED!)
PETPOOJA_APP_KEY=your_app_key_here
PETPOOJA_APP_SECRET=your_app_secret_here
PETPOOJA_ACCESS_TOKEN=your_access_token_here

# Restaurant identification (OPTIONAL - Auto-detected from API)
# You don't need to set this! The onboarding endpoint will fetch it automatically.
# Only set if you want to override the auto-detection.
PETPOOJA_RESTAURANT_ID=your_restaurant_id

# =============================================================================
# PetPooja Sandbox Configuration (for testing)
# Access via: https://partner.petpooja.com
# Use these settings when testing in sandbox environment
# =============================================================================

# Sandbox-specific URLs
PETPOOJA_SANDBOX_ENABLED=false
PETPOOJA_SANDBOX_BASE_URL=https://qle1yy2ydc.execute-api.ap-southeast-1.amazonaws.com/V1
PETPOOJA_SANDBOX_DASHBOARD_URL=https://partner.petpooja.com

# Sandbox credentials (obtain from PetPooja partner portal)
# ONLY THESE 3 ARE REQUIRED - restaurant ID will be auto-detected!
PETPOOJA_SANDBOX_APP_KEY=your_sandbox_app_key
PETPOOJA_SANDBOX_APP_SECRET=your_sandbox_app_secret
PETPOOJA_SANDBOX_ACCESS_TOKEN=your_sandbox_access_token
# OPTIONAL - Auto-detected, only set to override
PETPOOJA_SANDBOX_RESTAURANT_ID=your_sandbox_restaurant_id

# =============================================================================
# PetPooja API Endpoints
# =============================================================================

# Save Order API endpoint (for placing orders on PetPooja POS)
PETPOOJA_SAVE_ORDER_ENDPOINT=/save_order

# Other PetPooja endpoints
PETPOOJA_FETCH_MENU_ENDPOINT=/getrestaurantdetails
PETPOOJA_FETCH_RESTAURANT_ENDPOINT=/getrestaurantdetails

# =============================================================================
# Webhook & Callback Configuration
# =============================================================================

# Webhook Security - Secret key for HMAC signature validation
WEBHOOK_SECRET=your_webhook_secret_key_for_hmac_validation

# Callback URL - Where PetPooja will send order status updates
# Format: https://yourdomain.com/api/petpooja/callback
# This URL must be publicly accessible and configured in PetPooja dashboard
PETPOOJA_CALLBACK_URL=https://yourdomain.com/api/petpooja/callback

# Webhook endpoints (where we receive PetPooja webhooks)
PETPOOJA_WEBHOOK_ENDPOINT=/webhook

# =============================================================================
# Main Backend Integration
# =============================================================================

# Main backend URL and authentication
MAIN_BACKEND_URL=http://localhost:3000
MAIN_BACKEND_API_TOKEN=your_backend_auth_token

# Main backend webhook forwarding endpoint
MAIN_BACKEND_WEBHOOK_ENDPOINT=/api/webhooks/petpooja

# Server Configuration
API_HOST=0.0.0.0
API_PORT=8001
DEBUG=false

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/petpooja_microservice.log

# Retry Configuration
HTTP_TIMEOUT=30
HTTP_MAX_RETRIES=3
HTTP_RETRY_DELAY=2

# =============================================================================
# Security Configuration
# =============================================================================

# Encryption Key for credentials at rest (Fernet symmetric encryption)
# Generate a new key by running: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# IMPORTANT: Use different keys for dev/staging/production environments
# CRITICAL: Store production key in a secrets manager, NOT in git!
ENCRYPTION_KEY=your_base64_encoded_fernet_key_here

# CORS Allowed Origins (comma-separated list)
# Production: Set to your actual frontend domains
# Development: Can use http://localhost:3000 for local testing
# NEVER use "*" in production!
ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com

# Rate Limiting (requests per minute per IP)
# Adjust based on your expected traffic patterns
RATE_LIMIT_PER_MINUTE=60
